config {
  type: "view",
  schema: "dataform_staging",
  description: "Limpieza de ordenes: estandarización de estados y fechas",
  tags: ["staging"]
}

SELECT
  order_id,
  user_id,
  product_id,
  UPPER(status) as status,
  amount as sale_price,   
  country,
  created_at,
  DATE(created_at) as order_date 
FROM
  ${ref("orders")}
WHERE
  amount > 0